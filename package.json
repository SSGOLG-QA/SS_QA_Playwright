{
  "name": "playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "auth": "playwright test --project=setup --headed",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "playwright test --project=admin-chromium Admin/all-suite.spec.ts --no-deps",
    "test:all": "playwright test --project=admin-chromium Admin/all-suite.spec.ts --no-deps",
    "test:admin": "playwright test --project=admin-chromium --no-deps",
    "test:ia": "playwright test --project=admin-chromium Admin/ia-order-full.spec.ts --no-deps --workers=1",
    "test:l4": "playwright test --project=admin-chromium Admin/l4-reconcile.spec.ts --no-deps",
    "test:lang": "playwright test --project=admin-chromium Admin/lang-check-all.spec.ts --no-deps",
    "test:e2e": "playwright test --config=Playwright_New/playwright.config.ts",
    "test:full": "playwright test --project=admin-chromium --no-deps --workers=1 Admin/all-suite.spec.ts Admin/l4-reconcile.spec.ts Admin/ux-probe-all.spec.ts && playwright test --config=Playwright_New/playwright.config.ts",
    "report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0"
  }
}
